# ──────────────────────────────────────────────────────────────────────────────
# AI Ads Supervisor — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL for the backend API.
# Must NOT have a trailing slash.
# Example: http://localhost:8000/api  (local dev)
#          https://api.decoinks.com/api  (production)
VITE_API_URL=http://localhost:8000/api

# Set to "true" to bypass real API calls and use local fixture data.
# Useful for UI development without a running backend.
# Set to "false" (or remove) for staging / production.
VITE_USE_MOCKS=true
